# ───────────────────────────────────────────
# Stripe Wallet API — Environment Variables
# ───────────────────────────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Database ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stripe_wallet
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# ── Redis ─────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ── Stripe (Test Mode) ────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# Get this after registering a webhook endpoint in Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── JWT ───────────────────────────────────
# Generate a secure base64 secret: openssl rand -base64 64
JWT_SECRET=your_base64_jwt_secret_here

# ── App ───────────────────────────────────
APP_BASE_URL=http://localhost:8080
